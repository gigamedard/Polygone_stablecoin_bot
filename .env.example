# Connexion Blockchain (archive RPC requis pour les tests fork)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/VOTRE_CLE_API
PRIVATE_KEY=0xVotreCléPrivée

# Mode : BACKTEST | DEMO | PRODUCTION
MODE=DEMO

# Stratégie : FREE_MARKET | TIERED
STRATEGY=TIERED

MIN_PROFIT_PERCENT=0.01
SLIPPAGE_TOLERANCE=0.001
CAPITAL_AMOUNT=10000
MAX_HOPS=2
POLLING_INTERVAL=5000

# Adresse du contrat FlashArbitrage déployé
# FLASH_ARBITRAGE_ADDRESS=0x...

# Variables d'environnement de test fork
# FORK_ENABLED=true
# FORK_BLOCK=87360000
